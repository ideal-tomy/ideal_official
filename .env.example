# AIコンシェルジュ（C3）— サーバー側のみ。クライアントに露出させないこと。
# 未設定の場合でも選択式フロー + テンプレート結果は動作します。

OPENAI_API_KEY=
# 省略時: https://api.openai.com/v1
# OPENAI_BASE_URL=
# 省略時: gpt-4o-mini
# OPENAI_MODEL=

# sitemap / robots 用（本番ドメイン）
# NEXT_PUBLIC_SITE_URL=https://example.com

# 自動見積もり埋め込み（/estimate）— 末尾スラッシュなし
# 例: https://estimate.example.com
# NEXT_PUBLIC_ESTIMATE_EMBED_ORIGIN=https://estimate.example.com
