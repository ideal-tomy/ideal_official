# サイト案内コンシェルジュ — サーバー側のみ。クライアントに露出させないこと。
# 未設定の場合でもキーワード／チップのテンプレート案内は動作します。
# AI はルール不一致時の意図分類にのみ使います。

OPENAI_API_KEY=
# 省略時: https://api.openai.com/v1
# OPENAI_BASE_URL=
# 省略時: gpt-4o-mini
# OPENAI_MODEL=
# 根拠つき短文生成（初期オフ。1 で有効化）
# CONCIERGE_GUIDE_GROUNDED=0

# sitemap / robots 用（本番ドメイン）
# NEXT_PUBLIC_SITE_URL=https://example.com

# 自動見積もり（/estimate）→ roi-simulator フル版（オリジンのみ・末尾スラッシュなし）
# 例: https://roi-simulator-eta.vercel.app
# NEXT_PUBLIC_ROI_SIMULATOR_URL=https://roi-simulator-eta.vercel.app

# お問い合わせ送信（/api/contact）— 未設定時は送信失敗（偽の成功表示なし）
# Zapier / Make / Discord Incoming Webhook 等の受け口 URL
# CONTACT_WEBHOOK_URL=https://hooks.example.com/...
# 任意: Authorization: Bearer に付与
# CONTACT_WEBHOOK_SECRET=
